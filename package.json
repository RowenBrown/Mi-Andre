      <div style={{ width: 220, background: "#1a1a2e", color: "#fff", padding: 20 }}>
        <h2>SocialHQ</h2>
        <button onClick={() => setTab("dashboard")} style={sideBtn}>Dashboard</button>
        <button onClick={() => setTab("calendar")} style={sideBtn}>Calendario</button>
        <button onClick={() => setTab("weekly")} style={sideBtn}>Semana</button>
      </div>
      <div style={{ flex: 1, padding: 32 }}>
        {tab === "dashboard" && <h1>Bienvenido, Rowema</h1>}
        {tab === "calendar" && <CalendarView posts={posts} />}
        {tab === "weekly" && <WeeklyView posts={posts} />}
